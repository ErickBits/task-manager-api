  "description": "RESTful API for task management with JWT authentication, built with Node.js, Express and MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --coverage"
  },
  "keywords": ["nodejs", "express", "mongodb", "jwt", "docker", "aws"],
  "author": "",
